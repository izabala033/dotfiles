[
  {
    "name": "main-bar",
    "layer": "bottom",
    "position": "top",
    "height": 40,
    "margin": "3, 4, 0, 4",
    "modules-left": [
      "custom/icon",
      "hyprland/workspaces",
      "mpris"
    ],
    "modules-center": [
      "hyprland/window"
    ],
    "modules-right": [
      "memory",
      "cpu",
      "pulseaudio",
      "network",
      "battery",
      "clock"
    ],
    "reload_style_on_change": true,
    "hyprland/workspaces": {
      "format": "{icon}",
      "all-outputs": false,
      "format-icons": {
        "1": "一",
        "2": "二",
        "3": "三",
        "4": "四",
        "5": "五",
        "6": "六",
        "7": "七",
        "8": "八",
        "9": "九",
        "10": "十"
      }
    },
    "custom/icon": {
      "format": ""
    },
    "clock": {
      "rotate": 0,
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "format": " {:%I:%M %p}",
      "format-alt": " {:%a, %b %d}",
      "calendar": {
        "format": {
          "today": "<span color='#ffffff'><b>{}</b></span>"
        }
      },
      "on-click-right": "wezterm start calcurse"
    },
    "battery": {
      "states": {
        "good": 95,
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-charging": " {capacity}%",
      "format-plugged": " {capacity}%",
      "format-icons": [
        " ",
        " ",
        " ",
        " ",
        " "
      ],
      "format-alt": "{time}"
    },
    "network": {
      "format": "{icon} ",
      "format-alt-click": "click-right",
      "format-wifi": "{icon} ",
      "format-disconnected": "{icon} Disconnected",
      "format-icons": {
        "wifi": [
          "󰖩"
        ],
        "disconnected": [
          "󰖪"
        ]
      },
      "on-click": "wezterm start nmtui",
      "tooltip-format": "{ifname}: {ipaddr}"
    },
    "pulseaudio": {
      "format": "{icon}{volume}%",
      "format-muted": " ",
      "format-source": " {volume}%",
      "format-source-muted": "",
      "format-icons": {
        "default": [
          " ",
          " ",
          " "
        ]
      },
      "on-click": "pavucontrol"
    },
    "mpris": {
      "interval": 1,
      "format": " {player_icon} {title} - {artist}",
      "format-paused": " {status_icon} <i>{title} - {artist}</i>",
      "player-icons": {
        "default": "▶"
      },
      "status-icons": {
        "paused": "⏸"
      },
      "max-length": 20,
      "ignored-players": [
        "firefox"
      ]
    },
    "hyprland/window": {
      "format": "{title}",
      "separate-outputs": true,
      "icon": true,
      "max-length": 25
    },
    "memory": {
      "interval": 30,
      "format": " {used:0.1f}G/{total:0.1f}G"
    },
    "cpu": {
      "interval": 1,
      "format": "  {usage}%",
      "format-alt": " {avg_frequency}"
    }
  }
]
